{
    "appearance": {
        "transparency": {
            "enabled": true
        }
    },
    "background": {
        "wallpaperEnabled": true
    },
    "bar": {
        "persistent": false
    },
    "dashboard": {
        "enabled": true,
        "showDashboard": true,
        "showOnHover": true
    },
    "launcher": {
        "maxWallpapers": 9,
        "showOnHover": false,
        "useFuzzy": {
            "wallpapers": false
        }
    },
    "paths": {
        "wallpaperDir": "~/wallpapers"
    },
    "services": {
        "audioIncrement": 0.05,
        "brightnessIncrement": 0.05,
        "defaultPlayer": "Mozilla firefox",
        "lyricsBackend": "LyricsBackend::Auto",
        "maxVolume": 1,
        "useFahrenheit": false
    },
    "sidebar": {
        "enabled": true
    }
}
